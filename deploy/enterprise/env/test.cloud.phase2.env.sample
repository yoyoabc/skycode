# Phase 2 — platform profile（在 Phase 1 .env 基础上追加）
# 用法：合并到 deploy/enterprise/.env，或 cp 后按需修改

# --- Phase 1（保留）---
KILO_SERVER_PASSWORD=CHANGE-TEST-STRONG-PASSWORD
KILO_ENGINE_IMAGE=kilo-engine:local
KILO_ENGINE_BIND=127.0.0.1:4096
KILO_DISABLE_AUTOCOMPACT=1
KILO_CUSTOM_API_KEY=sk-your-api-key
KILO_ENGINE_CONFIG=./config/deepseek.kilo.jsonc

APISIX_HTTP_BIND=0.0.0.0:9080
BRIDGE_BIND=127.0.0.1:8080

# --- Phase 2 L3 platform ---
PLATFORM_PG_USER=kilo
PLATFORM_PG_PASSWORD=CHANGE-PLATFORM-PG-PASSWORD
PLATFORM_PG_DB=enterprise
# PG/Redis 仅容器内网访问（platform 经 postgres:5432 / redis:6379 连接），无需映射宿主机端口
# 若本机调试需直连，可临时加：PLATFORM_PG_BIND=127.0.0.1:5432  PLATFORM_REDIS_BIND=127.0.0.1:6380
PLATFORM_BIND=127.0.0.1:8090

# W3 Auth / JWT（须与 apisix/apisix.yaml consumer secret 一致）
PLATFORM_JWT_SECRET=change-me-enterprise-jwt-secret-32chars
PLATFORM_JWT_KEY=enterprise-jwt
PLATFORM_AUTH_DEV=0

# W4：模型配置下发（compose 内 platform 写 /config-out/generated.kilo.jsonc）
# KILO_ENGINE_CONFIG=./config/generated.kilo.jsonc

# SSO（推荐 Logto，见 docs/enterprise/LOGTO-SSO.md）
# PLATFORM_OIDC_CLIENT_ID=<logto-app-id>
# PLATFORM_OIDC_CLIENT_SECRET=<logto-app-secret>
# PLATFORM_OIDC_VSCODE_URI=vscode://yoyo-local.yoyo-code/enterprise/callback
