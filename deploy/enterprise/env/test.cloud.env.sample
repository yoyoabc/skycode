# 测试环境（公网云）— 复制为 deploy/enterprise/.env 后修改
# 详见 docs/enterprise/PHASE1-DEPLOY-ENVIRONMENTS.md

KILO_SERVER_PASSWORD=CHANGE-TEST-STRONG-PASSWORD
KILO_ENGINE_IMAGE=kilo-engine:local

KILO_ENGINE_BIND=127.0.0.1:4096
QDRANT_BIND=127.0.0.1:6333
BRIDGE_BIND=127.0.0.1:8080
LICENSE_MOCK_BIND=127.0.0.1:19090
APISIX_HTTP_BIND=0.0.0.0:9080

# 模式 A：外部 API — 推荐用专用模板：
#   cp env/test.cloud.api.env.sample .env
KILO_CUSTOM_API_KEY=sk-your-api-key
KILO_ENGINE_CONFIG=./config/deepseek.kilo.jsonc

# 模式 B：同机 vLLM 时改为：
# KILO_CUSTOM_API_BASE_URL=http://vllm:8000/v1
# VLLM_BIND=127.0.0.1:8000
# VLLM_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct
