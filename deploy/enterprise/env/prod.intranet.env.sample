# 生产环境（纯内网）— 复制为 deploy/enterprise/.env 后修改
# 所有 URL 必须为内网地址；密码与测试环境不同

KILO_SERVER_PASSWORD=CHANGE-PROD-STRONG-PASSWORD
KILO_ENGINE_IMAGE=kilo-engine:local

KILO_ENGINE_BIND=127.0.0.1:4096
QDRANT_BIND=127.0.0.1:6333
BRIDGE_BIND=127.0.0.1:8080
LICENSE_MOCK_BIND=127.0.0.1:19090
APISIX_HTTP_BIND=0.0.0.0:9080

# 内网模型网关（不出域）
KILO_CUSTOM_API_BASE_URL=http://llm-gateway.internal/v1
KILO_CUSTOM_API_KEY=

# 或内网 GPU 机 vLLM：
# KILO_CUSTOM_API_BASE_URL=http://10.0.20.5:8000/v1
