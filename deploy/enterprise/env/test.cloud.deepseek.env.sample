# 测试云 — DeepSeek 官方 API（对比 Ruiyu MaaS 是否「停不下来」）
# 用法：cp env/test.cloud.deepseek.env.sample .env && nano .env

KILO_SERVER_PASSWORD=CHANGE-TEST-STRONG-PASSWORD
KILO_ENGINE_IMAGE=kilo-engine:local

KILO_ENGINE_BIND=127.0.0.1:4096
QDRANT_BIND=127.0.0.1:6333
BRIDGE_BIND=127.0.0.1:8080
LICENSE_MOCK_BIND=127.0.0.1:19090
APISIX_HTTP_BIND=0.0.0.0:9080

KILO_DISABLE_AUTOCOMPACT=1

# DeepSeek 官方 Key（仅写在云机 .env，勿提交 Git）
# 文档：OpenAI 兼容 Base URL https://api.deepseek.com/v1；模型 deepseek-v4-pro / deepseek-v4-flash
KILO_CUSTOM_API_KEY=sk-your-deepseek-key
# 勿设 KILO_CUSTOM_API_BASE_URL，否则会覆盖 deepseek.kilo.jsonc 里的 baseURL
KILO_ENGINE_CONFIG=./config/deepseek.kilo.jsonc
# POC 验证「停不下来」：
#   ./config/deepseek.poc-no-tools.kilo.jsonc  — 仅改 tool_call 标记（实际仍会向 API 发 tools，效果有限）
#   ./config/deepseek.poc-minimal.kilo.jsonc   — ask 模式 + steps:1 + flash（推荐下一步）
# KILO_ENGINE_CONFIG=./config/deepseek.poc-minimal.kilo.jsonc
